# ── Secrets (NEVER commit real keys) ────────────────────────────────────────────
# Path to GCP service account JSON (used by HMS, Trino, and should match Spark key path strategy).
# Example (Windows): GCP_SERVICE_ACCOUNT_KEY=C:\keys\project-sa.json
# Example (Linux):   GCP_SERVICE_ACCOUNT_KEY=/home/you/.config/gcloud/legacy_credentials/xxx.json
GCP_SERVICE_ACCOUNT_KEY=

GCP_PROJECT_ID=your-gcp-project
GCP_REGION=us-east-1
GCS_BUCKET=crypto-lakehouse-group8
HIVE_METASTORE_WAREHOUSE_DIR=gs://crypto-lakehouse-group8/bronze/

KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC_RAW=crypto_trades_raw
KAFKA_TOPIC_DLQ=crypto_trades_dlq

# Optional: local batch ingestion still expects S3-compatible storage unless migrated to GCS.
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=admin123

POSTGRES_USER=hive
POSTGRES_PASSWORD=hivepassword
POSTGRES_DB=metastore

HIVE_METASTORE_URI=thrift://hive-metastore:9083

BINANCE_REST_URL=https://api.binance.com
BINANCE_WS_URL=wss://stream.binance.com:9443/stream
